{
  "name": "@cinatra-ai/dev",
  "version": "0.2.2",
  "description": "Cinatra dev skills for Claude Code — set up and build with Cinatra (public).",
  "type": "module",
  "bin": {
    "cinatra-dev-install": "bin/install.mjs"
  },
  "files": [
    "bin/",
    "skills-src/",
    "payload/",
    "VERSION",
    "version.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "install:claude": "node bin/install.mjs --claude --global",
    "uninstall:claude": "node bin/uninstall.mjs --claude --global",
    "test": "node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cinatra-ai/dev.git"
  }
}
